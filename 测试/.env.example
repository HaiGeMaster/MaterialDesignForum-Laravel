# ==========================================
# 应用基础配置
# ==========================================
APP_NAME=MaterialDesignForum
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# 默认语言
APP_LOCALE=zh_CN
# 回退语言（当前语言缺失时使用）
APP_FALLBACK_LOCALE=en_US
# 假数据生成语言
APP_FAKER_LOCALE=en_US

# 维护模式驱动（file / database）
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP 内置服务器 Worker 数
# PHP_CLI_SERVER_WORKERS=4

# ==========================================
# 密码加密
# ==========================================
# Bcrypt 加密轮数（越高越安全，也越慢）
BCRYPT_ROUNDS=12

# ==========================================
# 日志配置
# ==========================================
# 日志通道（stack=多通道, single=单文件, daily=按天切割）
LOG_CHANNEL=stack
# stack 驱动组合的通道
LOG_STACK=single
# 废弃方法警告通道
LOG_DEPRECATIONS_CHANNEL=null
# 日志级别（debug/info/notice/warning/error/critical/alert/emergency）
LOG_LEVEL=debug

# ==========================================
# 数据库配置
# ==========================================
# 数据库类型（mysql/pgsql/sqlite/sqlsrv）
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=
# 严格模式（关闭后允许无默认值字段插入）
DB_STRICT=false

# ==========================================
# Session 配置
# ==========================================
# Session 驱动（file/cookie/database/redis）
SESSION_DRIVER=file
# Session 有效期（分钟）
SESSION_LIFETIME=120
# 是否加密 Session 数据
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ==========================================
# 广播 / 文件 / 队列 / 缓存
# ==========================================
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# 队列驱动（database/redis/sync）
QUEUE_CONNECTION=database

# 缓存驱动（database/file/redis/memcached）
CACHE_STORE=database
# CACHE_PREFIX=

# ==========================================
# Memcached / Redis
# ==========================================
MEMCACHED_HOST=127.0.0.1

# Redis 客户端（phpredis/predis）
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ==========================================
# 邮件配置（SMTP）
# ==========================================
# 邮件驱动（smtp/sendmail/mailgun/log/array）
MAIL_MAILER=smtp
# SMTP 服务器地址
MAIL_HOST=smtp.qq.com
# SMTP 端口（25/465-SSL/587-TLS）
MAIL_PORT=465
# 加密方式（ssl/tls/null）
MAIL_ENCRYPTION=ssl
# 发件邮箱账号
MAIL_USERNAME=
# 邮箱授权码（非登录密码）
MAIL_PASSWORD=
# 发件人地址
MAIL_FROM_ADDRESS=
# 发件人名称
MAIL_FROM_NAME=MaterialDesignForum

# ==========================================
# AWS S3 存储（可选）
# ==========================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# 前端环境变量前缀
VITE_APP_NAME="${APP_NAME}"

# ==========================================
# OAuth 第三方登录
# ==========================================
# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:82/auth/github/callback

# Microsoft Azure OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:82/auth/microsoft/callback
# Azure 租户类型（common=所有用户, organizations=仅工作账号, consumers=仅个人账号, 或指定 tenant ID）
MICROSOFT_TENANT_ID=common

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:82/auth/google/callback
